{
  "name": "react-timer",
  "version": "0.0.1",
  "description": "Self-disposing timer (setTimeout, setInterval, etc.) for React components",
  "author": "Joost Lubach",
  "private": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "module": "./dist/esm/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && npm run build:tsc",
    "build:tsc": "npm run build:tsc:esm && npm run build:tsc:cjs",
    "build:tsc:esm": "tsc -p tsconfig.prod.json --module es2022 --outDir dist/esm --declarationDir dist/types",
    "build:tsc:cjs": "tsc -p tsconfig.prod.json --module commonjs --outDir dist/cjs --declaration false --declarationMap false",
    "clean": "rimraf dist",
    "lint": "eslint",
    "check": "tsc -p . --noEmit",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": "^19.1"
  },
  "devDependencies": {
    "@types/react": "^19.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unused-imports": "^4.3.0",
    "rimraf": "6.0.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "ytil": "workspace:^"
  },
  "packageManager": "pnpm@9.9.0"
}
